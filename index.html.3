            const guests = document.getElementById('rsvpGuests').value;
            const events = document.getElementById('rsvpEvents').value;

            if (!name || !phone || !attending) {
                document.getElementById('rsvpForm').reportValidity();
                return;
            }

            const selectionText = attending.value;
            const textMsg = selectionText.includes("Regretfully") 
                ? "Thank you for letting us know. You will be missed!" 
                : `We are thrilled to welcome you (${guests} guest(s)) for the ${events}!`;

